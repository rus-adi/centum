generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  IT
  COACH
  TEACHER
}

enum StudentStatus {
  ACTIVE
  PENDING
  DISABLED
}

enum RequestStatus {
  SUBMITTED
  IN_PROGRESS
  COMPLETED
}

enum RequestDecision {
  PENDING
  APPROVED
  DENIED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  INFO
  ACTION
  ALERT
}


enum SchoolStage {
  ONBOARDING
  FOUNDATION
  PILOT
  SCALE
}

enum SchoolType {
  PUBLIC
  PRIVATE
  INTERNATIONAL
  HYBRID
}

enum DeviceModel {
  ONE_TO_ONE
  SHARED
  LAB_ONLY
  BYOD
}

enum Ecosystem {
  GOOGLE
  MICROSOFT
  MIXED
}

enum Connectivity {
  LOW
  MEDIUM
  HIGH
}

enum GateStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

model School {
  id        String   @id @default(cuid())
  name      String
  city      String
  timezone  String   @default("Asia/Jakarta")
  createdAt DateTime @default(now())

  // School profile (Investor MVP)
  type             SchoolType?
  curriculum       String?
  gradeBands       Json?
  studentCount     Int?
  deviceModel      DeviceModel?
  ecosystem        Ecosystem?
  connectivity     Connectivity?
  constraints      String?
  priorityOutcomes Json?

  // Transformation status (Investor MVP)
  transformationStage    SchoolStage @default(ONBOARDING)
  transformationProgress Int         @default(0)

  users       User[]
  students    Student[]
  tools       SchoolTool[]
  requests    Request[]
  tickets     Ticket[]
  updates     UpdatePost[]
  auditLogs   AuditLog[]
  attachments FileAttachment[]
  notifications Notification[]

  gates ImplementationGate[]

  // Required inverse relations for token + usage logging models
  inviteTokens InviteToken[]
  toolUsageLogs ToolUsageLog[]

  @@index([createdAt])
}


model ImplementationGate {
  id          String     @id @default(cuid())
  schoolId    String
  school      School     @relation(fields: [schoolId], references: [id])

  key         String
  title       String
  description String?
  order       Int        @default(0)
  status      GateStatus @default(NOT_STARTED)

  completedAt DateTime?
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())

  @@unique([schoolId, key])
  @@index([schoolId, order])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  excerpt   String?
  body      String
  published Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([published, createdAt])
}

model StackBundle {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  category    String
  description String
  toolKeys    Json?

  createdAt DateTime @default(now())

  @@index([category])
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(STAFF)
  active    Boolean  @default(true)

  // SUPER_ADMIN can have no primary school; they switch via cookie-based context
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())

  submittedRequests Request[] @relation("SubmittedRequests")
  assignedRequests  Request[] @relation("AssignedRequests")

  submittedTickets Ticket[] @relation("SubmittedTickets")
  assignedTickets  Ticket[] @relation("AssignedTickets")

  requestComments RequestComment[]
  ticketComments  TicketComment[]

  trainingProgress    TrainingProgress[]
  trainingCompletions TrainingCompletion[]

  auditActor AuditLog[] @relation("AuditActor")
  inviteSent InviteToken[] @relation("InviteSender")
  passwordResetTokens PasswordResetToken[]
  notifications Notification[]
  attachments FileAttachment[] @relation("AttachmentUploader")

  // Inverse relations (required by Prisma) for event/log models
  toolUsageLogs ToolUsageLog[]
  requestEvents RequestEvent[]
  ticketEvents TicketEvent[]

  @@index([schoolId])
  @@index([role])
}

model AuthAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model InviteToken {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])

  email       String
  role        UserRole @default(STAFF)

  tokenHash   String
  invitedById String?
  invitedBy   User?    @relation("InviteSender", fields: [invitedById], references: [id])

  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])

  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])

  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  schoolId  String?
  school    School?          @relation(fields: [schoolId], references: [id])

  userId    String
  user      User             @relation(fields: [userId], references: [id])

  type      NotificationType @default(INFO)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([schoolId, createdAt])
}

model Student {
  id         String        @id @default(cuid())
  schoolId   String
  school     School        @relation(fields: [schoolId], references: [id])

  // Optional unique identifier per school (recommended for imports)
  studentCode String?

  name       String
  grade      Int
  status     StudentStatus @default(ACTIVE)
  coachName  String?

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  toolAccess StudentToolAccess[]
  requests   Request[]

  // Inverse relation for usage logging
  toolUsageLogs ToolUsageLog[]

  @@unique([schoolId, studentCode])
  @@index([schoolId, name])
}

model Tool {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String

  schoolTools    SchoolTool[]
  studentAccess  StudentToolAccess[]
  usageLogs      ToolUsageLog[]
  requests       Request[]
  requirements   ToolRequirement[]

  @@index([name])
}


model ToolRequirement {
  id       String @id @default(cuid())
  toolId   String
  tool     Tool   @relation(fields: [toolId], references: [id])

  moduleId String
  module   TrainingModule @relation(fields: [moduleId], references: [id])

  createdAt DateTime @default(now())

  @@unique([toolId, moduleId])
  @@index([moduleId])
}


model SchoolTool {
  id        String   @id @default(cuid())
  schoolId  String
  toolId    String

  school    School   @relation(fields: [schoolId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  enabled   Boolean  @default(true)
  eligible  String   @default("Grades 7–12")
  updatedAt DateTime @updatedAt

  @@unique([schoolId, toolId])
  @@index([schoolId, enabled])
}

model StudentToolAccess {
  id        String   @id @default(cuid())
  studentId String
  toolId    String

  student   Student  @relation(fields: [studentId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([studentId, toolId])
  @@index([toolId])
}

model ToolUsageLog {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  toolId    String
  tool      Tool     @relation(fields: [toolId], references: [id])

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])

  eventType String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

model Request {
  id            String         @id @default(cuid())
  schoolId      String
  school        School         @relation(fields: [schoolId], references: [id])

  kind          String         @default("GENERAL") // GENERAL | TOOL_ENABLE | STUDENT_TOOL_ACCESS
  type          String
  description   String?

  status        RequestStatus  @default(SUBMITTED)
  decision      RequestDecision @default(PENDING)

  submittedById String?
  submittedBy   User?          @relation("SubmittedRequests", fields: [submittedById], references: [id])

  assignedToId  String?
  assignedTo    User?          @relation("AssignedRequests", fields: [assignedToId], references: [id])

  // Optional tool/student data for provisioning requests
  toolId        String?
  tool          Tool?          @relation(fields: [toolId], references: [id])

  studentId     String?
  student       Student?       @relation(fields: [studentId], references: [id])

  desiredSchoolToolEnabled   Boolean?
  desiredStudentToolEnabled  Boolean?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  comments      RequestComment[]
  events        RequestEvent[]
  attachments   FileAttachment[]

  @@index([schoolId, createdAt])
  @@index([status, createdAt])
}

model RequestEvent {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id])

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])

  type      String   // e.g. status.changed, assigned, decision.approved, attachment.added
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([requestId, createdAt])
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id])

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])

  body      String
  createdAt DateTime @default(now())

  @@index([requestId, createdAt])
}

model Ticket {
  id            String       @id @default(cuid())
  schoolId      String
  school        School       @relation(fields: [schoolId], references: [id])

  category      String
  subject       String
  description   String

  status        TicketStatus @default(OPEN)

  submittedById String?
  submittedBy   User?        @relation("SubmittedTickets", fields: [submittedById], references: [id])

  assignedToId  String?
  assignedTo    User?        @relation("AssignedTickets", fields: [assignedToId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  comments      TicketComment[]
  events        TicketEvent[]
  attachments   FileAttachment[]

  @@index([schoolId, createdAt])
  @@index([status, createdAt])
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])

  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])

  body      String
  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model TrainingModule {
  id             String   @id @default(cuid())
  key            String   @unique
  title          String
  description    String
  totalLessons   Int      @default(5)
  currentVersion Int      @default(1)

  createdAt DateTime @default(now())

  progresses       TrainingProgress[]
  completions      TrainingCompletion[]
  updates          UpdatePost[]
  toolRequirements ToolRequirement[]

  @@index([createdAt])
}


model TrainingProgress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  moduleId        String
  module          TrainingModule @relation(fields: [moduleId], references: [id])

  version         Int
  lessonsCompleted Int     @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([userId, moduleId, version])
}

model TrainingCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  moduleId    String
  module      TrainingModule @relation(fields: [moduleId], references: [id])

  version     Int
  completedAt DateTime @default(now())

  @@unique([userId, moduleId, version])
}

model UpdatePost {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  month     String
  title     String
  body      String

  requiresTraining Boolean @default(false)
  trainingModuleId String?
  trainingModule   TrainingModule? @relation(fields: [trainingModuleId], references: [id])
  newTrainingVersion Int?

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
}

model FileAttachment {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  uploadedById String?
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  requestId String?
  request   Request? @relation(fields: [requestId], references: [id])

  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])

  bucket    String
  path      String
  filename  String
  mimeType  String
  size      Int

  createdAt DateTime @default(now())

  @@index([schoolId, createdAt])
  @@index([requestId])
  @@index([ticketId])
}

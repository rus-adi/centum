generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                          String                  @id @default(cuid())
  name                        String
  city                        String
  region                      String?
  timezone                    String                  @default("Asia/Jakarta")
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  type                        SchoolType?
  curriculum                  String?
  curriculumNotes             String?
  gradeBands                  Json?
  studentCount                Int?
  enrollment                  Int?
  staffCount                  Int?
  deviceModel                 DeviceModel?
  deviceRatio                 String?
  ecosystem                   Ecosystem?
  connectivity                Connectivity?
  constraints                 String?
  nonNegotiables              String?
  priorityOutcomes            Json?
  currentTooling              Json?
  budgetSensitivity           ToolCostTier?
  maturityScore               Int                     @default(0)
  readinessScore              Int                     @default(0)
  transformationStage         SchoolStage             @default(ONBOARDING)
  transformationProgress      Int                     @default(0)
  aiAdoptionGoal              String?
  individualizedLearningGoal  String?
  projectBasedLearningGoal    String?
  selGoal                     String?
  school2Vision               String?
  auditLogs                   AuditLog[]
  attachments                 FileAttachment[]
  bundleAdoptions             SchoolBundleAdoption[]
  copilotRuns                 CopilotRun[]
  gates                       ImplementationGate[]
  governanceDocuments         GovernanceDocument[]
  governanceQueries           GovernanceQuery[]
  growthAssets                GrowthAsset[]
  inviteTokens                InviteToken[]
  licenses                    License[]
  notifications               Notification[]
  packAdoptions               SchoolPackAdoption[]
  requests                    Request[]
  tickets                     Ticket[]
  toolRecommendations         ToolRecommendation[]
  tools                       SchoolTool[]
  students                    Student[]
  toolUsageLogs               ToolUsageLog[]
  updates                     UpdatePost[]
  users                       User[]

  @@index([createdAt])
  @@index([transformationStage])
  @@index([readinessScore])
}

model ImplementationGate {
  id          String     @id @default(cuid())
  schoolId    String
  key         String
  title       String
  description String?
  order       Int        @default(0)
  status      GateStatus @default(NOT_STARTED)
  completedAt DateTime?
  updatedAt   DateTime   @updatedAt
  createdAt   DateTime   @default(now())
  school      School     @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, key])
  @@index([schoolId, order])
}

model KnowledgeArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  excerpt   String?
  body      String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([published, createdAt])
}

model StackBundle {
  id                String                 @id @default(cuid())
  key               String                 @unique
  name              String
  category          String
  description       String
  overview          String?
  toolKeys          Json?
  recommendedRoles  Json?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  bundleAdoptions   SchoolBundleAdoption[]

  @@index([category])
}

model TransformationPack {
  id                         String               @id @default(cuid())
  key                        String               @unique
  slug                       String               @unique
  name                       String
  pillar                     PackPillar
  description                String
  overview                   String
  readinessChecklist         Json?
  implementationMilestones   Json?
  templateResources          Json?
  recommendedToolCategories  Json?
  optionalBundleKeys         Json?
  proofPoints                Json?
  nextActions                Json?
  suggestedTrainingKeys      Json?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  schoolAdoptions            SchoolPackAdoption[]

  @@index([pillar])
}

model SchoolPackAdoption {
  id          String          @id @default(cuid())
  schoolId    String
  packId      String
  status      AdoptionStatus  @default(RECOMMENDED)
  ownerId     String?
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  owner       User?           @relation("PackOwner", fields: [ownerId], references: [id])
  pack        TransformationPack @relation(fields: [packId], references: [id])
  school      School          @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, packId])
  @@index([schoolId, status])
}

model SchoolBundleAdoption {
  id          String          @id @default(cuid())
  schoolId    String
  bundleId    String
  status      AdoptionStatus  @default(RECOMMENDED)
  ownerId     String?
  notes       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bundle      StackBundle     @relation(fields: [bundleId], references: [id])
  owner       User?           @relation("BundleOwner", fields: [ownerId], references: [id])
  school      School          @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, bundleId])
  @@index([schoolId, status])
}

model User {
  id                          String               @id @default(cuid())
  email                       String               @unique
  name                        String
  password                    String
  role                        UserRole             @default(STAFF)
  active                      Boolean              @default(true)
  schoolId                    String?
  createdAt                   DateTime             @default(now())
  auditActor                  AuditLog[]           @relation("AuditActor")
  attachments                 FileAttachment[]     @relation("AttachmentUploader")
  assignedRequests            Request[]            @relation("AssignedRequests")
  assignedTickets             Ticket[]             @relation("AssignedTickets")
  bundleOwnerships            SchoolBundleAdoption[] @relation("BundleOwner")
  copilotRuns                 CopilotRun[]         @relation("CopilotAuthor")
  governanceDocumentsAuthored GovernanceDocument[] @relation("GovernanceDocumentAuthor")
  governanceQueries           GovernanceQuery[]    @relation("GovernanceQueryAuthor")
  governanceVersionsUploaded  GovernanceDocumentVersion[] @relation("GovernanceVersionUploader")
  growthAssetsAuthored        GrowthAsset[]        @relation("GrowthAssetAuthor")
  inviteSent                  InviteToken[]        @relation("InviteSender")
  notifications               Notification[]
  packOwnerships              SchoolPackAdoption[] @relation("PackOwner")
  passwordResetTokens         PasswordResetToken[]
  requestComments             RequestComment[]
  requestEvents               RequestEvent[]
  submittedRequests           Request[]            @relation("SubmittedRequests")
  submittedTickets            Ticket[]             @relation("SubmittedTickets")
  ticketComments              TicketComment[]
  ticketEvents                TicketEvent[]
  toolRecommendationsAuthored ToolRecommendation[] @relation("ToolRecommendationAuthor")
  toolUsageLogs               ToolUsageLog[]
  trainingCompletions         TrainingCompletion[]
  trainingProgress            TrainingProgress[]
  school                      School?              @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([role])
}

model AuthAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

model InviteToken {
  id          String    @id @default(cuid())
  schoolId    String
  email       String
  role        UserRole  @default(STAFF)
  tokenHash   String
  invitedById String?
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  invitedBy   User?     @relation("InviteSender", fields: [invitedById], references: [id])
  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, createdAt])
  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  schoolId   String
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  school     School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, createdAt])
  @@index([actorId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  schoolId  String?
  userId    String
  type      NotificationType @default(INFO)
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  school    School?          @relation(fields: [schoolId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
  @@index([schoolId, createdAt])
}

model Student {
  id            String              @id @default(cuid())
  schoolId      String
  studentCode   String?
  name          String
  grade         Int
  status        StudentStatus       @default(ACTIVE)
  coachName     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  requests      Request[]
  school        School              @relation(fields: [schoolId], references: [id])
  toolAccess    StudentToolAccess[]
  toolUsageLogs ToolUsageLog[]

  @@unique([schoolId, studentCode])
  @@index([schoolId, name])
}

model Tool {
  id                       String                @id @default(cuid())
  key                      String                @unique
  name                     String
  description              String
  category                 String?
  useCase                  String?
  visibility               ToolVisibility        @default(SCHOOL_VISIBLE)
  maturity                 ToolMaturity          @default(ESTABLISHED)
  costTier                 ToolCostTier          @default(MEDIUM)
  riskLevel                ToolRiskLevel         @default(MEDIUM)
  providerName             String?
  providerNotes            String?
  prerequisiteNotes        String?
  gradeSuitability         Json?
  recommendedRoles         Json?
  regionFit                Json?
  deviceRequirements       String?
  connectivityRequirement  Connectivity?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  licenses                 License[]
  requests                 Request[]
  schoolTools              SchoolTool[]
  studentAccess            StudentToolAccess[]
  recommendations          ToolRecommendation[]
  requirements             ToolRequirement[]
  usageLogs                ToolUsageLog[]

  @@index([name])
  @@index([visibility, costTier])
}

model ToolRequirement {
  id        String         @id @default(cuid())
  toolId    String
  moduleId  String
  createdAt DateTime       @default(now())
  module    TrainingModule @relation(fields: [moduleId], references: [id])
  tool      Tool           @relation(fields: [toolId], references: [id])

  @@unique([toolId, moduleId])
  @@index([moduleId])
}

model ToolRecommendation {
  id              String                @id @default(cuid())
  schoolId        String
  toolId          String
  reason          String
  status          RecommendationStatus  @default(PENDING)
  recommendedById String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  recommendedBy   User?                 @relation("ToolRecommendationAuthor", fields: [recommendedById], references: [id])
  school          School                @relation(fields: [schoolId], references: [id])
  tool            Tool                  @relation(fields: [toolId], references: [id])

  @@unique([schoolId, toolId])
  @@index([schoolId, status])
}

model SchoolTool {
  id                String   @id @default(cuid())
  schoolId          String
  toolId            String
  enabled           Boolean  @default(true)
  eligible          String   @default("Grades 7–12")
  recommended       Boolean  @default(false)
  implementationNotes String?
  updatedAt         DateTime @updatedAt
  school            School   @relation(fields: [schoolId], references: [id])
  tool              Tool     @relation(fields: [toolId], references: [id])

  @@unique([schoolId, toolId])
  @@index([schoolId, enabled])
}

model StudentToolAccess {
  id        String   @id @default(cuid())
  studentId String
  toolId    String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  @@unique([studentId, toolId])
  @@index([toolId])
}

model ToolUsageLog {
  id        String   @id @default(cuid())
  schoolId  String
  toolId    String
  studentId String?
  actorId   String?
  eventType String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student? @relation(fields: [studentId], references: [id])
  tool      Tool     @relation(fields: [toolId], references: [id])

  @@index([schoolId, createdAt])
}

model Request {
  id                        String           @id @default(cuid())
  schoolId                  String
  kind                      String           @default("GENERAL")
  type                      String
  description               String?
  status                    RequestStatus    @default(SUBMITTED)
  decision                  RequestDecision  @default(PENDING)
  submittedById             String?
  assignedToId              String?
  toolId                    String?
  studentId                 String?
  bundleKey                 String?
  packKey                   String?
  desiredSchoolToolEnabled  Boolean?
  desiredStudentToolEnabled Boolean?
  requestContext            Json?
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  attachments               FileAttachment[]
  assignedTo                User?            @relation("AssignedRequests", fields: [assignedToId], references: [id])
  school                    School           @relation(fields: [schoolId], references: [id])
  student                   Student?         @relation(fields: [studentId], references: [id])
  submittedBy               User?            @relation("SubmittedRequests", fields: [submittedById], references: [id])
  tool                      Tool?            @relation(fields: [toolId], references: [id])
  comments                  RequestComment[]
  events                    RequestEvent[]

  @@index([schoolId, createdAt])
  @@index([status, createdAt])
}

model RequestEvent {
  id        String   @id @default(cuid())
  requestId String
  actorId   String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  request   Request  @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt])
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  author    User?    @relation(fields: [authorId], references: [id])
  request   Request  @relation(fields: [requestId], references: [id])

  @@index([requestId, createdAt])
}

model Ticket {
  id            String           @id @default(cuid())
  schoolId      String
  category      String
  subject       String
  description   String
  status        TicketStatus     @default(OPEN)
  submittedById String?
  assignedToId  String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  attachments   FileAttachment[]
  assignedTo    User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  school        School           @relation(fields: [schoolId], references: [id])
  submittedBy   User?            @relation("SubmittedTickets", fields: [submittedById], references: [id])
  comments      TicketComment[]
  events        TicketEvent[]

  @@index([schoolId, createdAt])
  @@index([status, createdAt])
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  actorId   String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  author    User?    @relation(fields: [authorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id])

  @@index([ticketId, createdAt])
}

model TrainingModule {
  id               String               @id @default(cuid())
  key              String               @unique
  title            String
  description      String
  totalLessons     Int                  @default(5)
  currentVersion   Int                  @default(1)
  videoUrl         String?
  transcript       String?
  checklist        Json?
  quiz             Json?
  attestationText  String?
  requiredRoles    Json?
  pillar           PackPillar?
  createdAt        DateTime             @default(now())
  toolRequirements ToolRequirement[]
  completions      TrainingCompletion[]
  progresses       TrainingProgress[]
  updates          UpdatePost[]

  @@index([createdAt])
}

model TrainingProgress {
  id               String         @id @default(cuid())
  userId           String
  moduleId         String
  version          Int
  lessonsCompleted Int            @default(0)
  updatedAt        DateTime       @updatedAt
  module           TrainingModule @relation(fields: [moduleId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@unique([userId, moduleId, version])
}

model TrainingCompletion {
  id          String         @id @default(cuid())
  userId      String
  moduleId    String
  version     Int
  completedAt DateTime       @default(now())
  module      TrainingModule @relation(fields: [moduleId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  @@unique([userId, moduleId, version])
}

model UpdatePost {
  id                 String          @id @default(cuid())
  schoolId           String
  month              String
  title              String
  body               String
  requiresTraining   Boolean         @default(false)
  trainingModuleId   String?
  newTrainingVersion Int?
  createdAt          DateTime        @default(now())
  school             School          @relation(fields: [schoolId], references: [id])
  trainingModule     TrainingModule? @relation(fields: [trainingModuleId], references: [id])

  @@index([schoolId, createdAt])
}

model FileAttachment {
  id           String   @id @default(cuid())
  schoolId     String
  uploadedById String?
  requestId    String?
  ticketId     String?
  bucket       String
  path         String
  filename     String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())
  request      Request? @relation(fields: [requestId], references: [id])
  school       School   @relation(fields: [schoolId], references: [id])
  ticket       Ticket?  @relation(fields: [ticketId], references: [id])
  uploadedBy   User?    @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([schoolId, createdAt])
  @@index([requestId])
  @@index([ticketId])
}

model GovernanceDocument {
  id            String                     @id @default(cuid())
  schoolId      String
  title         String
  category      GovernanceCategory
  summary       String?
  description   String?
  pinned        Boolean                    @default(false)
  status        GovernanceDocumentStatus   @default(ACTIVE)
  createdById   String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  createdBy     User?                      @relation("GovernanceDocumentAuthor", fields: [createdById], references: [id])
  school        School                     @relation(fields: [schoolId], references: [id])
  versions      GovernanceDocumentVersion[]
  querySources  GovernanceQuerySource[]

  @@index([schoolId, category])
  @@index([schoolId, pinned])
}

model GovernanceDocumentVersion {
  id               String                   @id @default(cuid())
  documentId       String
  version          Int
  originalFilename String?
  mimeType         String?
  storagePath      String?
  body             String
  notes            String?
  uploadedById     String?
  createdAt        DateTime                 @default(now())
  document         GovernanceDocument       @relation(fields: [documentId], references: [id])
  uploadedBy       User?                    @relation("GovernanceVersionUploader", fields: [uploadedById], references: [id])
  chunks           GovernanceChunk[]
  querySources     GovernanceQuerySource[]

  @@unique([documentId, version])
  @@index([documentId, createdAt])
}

model GovernanceChunk {
  id           String                  @id @default(cuid())
  versionId    String
  ordinal      Int
  content      String
  keywordText  String?
  createdAt    DateTime                @default(now())
  querySources GovernanceQuerySource[]
  version      GovernanceDocumentVersion @relation(fields: [versionId], references: [id])

  @@unique([versionId, ordinal])
  @@index([versionId, ordinal])
}

model GovernanceQuery {
  id                     String                  @id @default(cuid())
  schoolId               String
  userId                 String?
  question               String
  answer                 String
  confidence             Int                     @default(50)
  usedFallback           Boolean                 @default(true)
  lowConfidence          Boolean                 @default(false)
  escalationRecommended  Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  school                 School                  @relation(fields: [schoolId], references: [id])
  user                   User?                   @relation("GovernanceQueryAuthor", fields: [userId], references: [id])
  sources                GovernanceQuerySource[]

  @@index([schoolId, createdAt])
}

model GovernanceQuerySource {
  id         String                     @id @default(cuid())
  queryId    String
  documentId String?
  versionId  String?
  chunkId    String?
  quote      String?
  relevance  Float?
  query      GovernanceQuery            @relation(fields: [queryId], references: [id])
  document   GovernanceDocument?        @relation(fields: [documentId], references: [id])
  version    GovernanceDocumentVersion? @relation(fields: [versionId], references: [id])
  chunk      GovernanceChunk?           @relation(fields: [chunkId], references: [id])

  @@index([queryId])
}

model CopilotRun {
  id                      String                  @id @default(cuid())
  schoolId                String
  createdById             String?
  title                   String                  @default("School 2.0 Copilot Run")
  readinessScore          Int
  maturityScore           Int
  maturitySummary         String
  blockers                Json?
  nextActions             Json?
  recommendedBundleKeys   Json?
  recommendedPackKeys     Json?
  suggestedTrainingKeys   Json?
  plan30                  Json?
  plan60                  Json?
  plan90                  Json?
  executiveSummary        String
  createdAt               DateTime                @default(now())
  createdBy               User?                   @relation("CopilotAuthor", fields: [createdById], references: [id])
  school                  School                  @relation(fields: [schoolId], references: [id])
  recommendations         CopilotRecommendation[]

  @@index([schoolId, createdAt])
}

model CopilotRecommendation {
  id           String                   @id @default(cuid())
  runId        String
  schoolId     String
  kind         CopilotRecommendationKind
  title        String
  description  String
  status       RecommendationStatus     @default(PENDING)
  metadata     Json?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  run          CopilotRun               @relation(fields: [runId], references: [id])
  school       School                   @relation(fields: [schoolId], references: [id])

  @@index([schoolId, kind])
}

model Vendor {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  website     String?
  description String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  licenses    License[]
}

model License {
  id                  String        @id @default(cuid())
  schoolId            String
  vendorId            String
  toolId              String?
  name                String
  status              LicenseStatus @default(PLANNING)
  seatsPurchased      Int?
  seatsAssigned       Int?
  renewalDate         DateTime?
  costNotes           String?
  ownerName           String?
  ownerEmail          String?
  implementationNotes String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  school              School        @relation(fields: [schoolId], references: [id])
  tool                Tool?         @relation(fields: [toolId], references: [id])
  vendor              Vendor        @relation(fields: [vendorId], references: [id])

  @@index([schoolId, status])
  @@index([vendorId])
}

model GrowthAsset {
  id          String          @id @default(cuid())
  schoolId    String?
  slug        String          @unique
  title       String
  type        GrowthAssetType
  audience    String?
  description String?
  body        String
  status      String          @default("ACTIVE")
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User?           @relation("GrowthAssetAuthor", fields: [createdById], references: [id])
  school      School?         @relation(fields: [schoolId], references: [id])

  @@index([schoolId, type])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  IT
  COACH
  TEACHER
}

enum StudentStatus {
  ACTIVE
  PENDING
  DISABLED
}

enum RequestStatus {
  SUBMITTED
  IN_PROGRESS
  COMPLETED
}

enum RequestDecision {
  PENDING
  APPROVED
  DENIED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum NotificationType {
  INFO
  ACTION
  ALERT
}

enum SchoolStage {
  ONBOARDING
  FOUNDATION
  PILOT
  SCALE
}

enum SchoolType {
  PUBLIC
  PRIVATE
  INTERNATIONAL
  HYBRID
}

enum DeviceModel {
  ONE_TO_ONE
  SHARED
  LAB_ONLY
  BYOD
}

enum Ecosystem {
  GOOGLE
  MICROSOFT
  MIXED
}

enum Connectivity {
  LOW
  MEDIUM
  HIGH
}

enum GateStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum GovernanceCategory {
  BEHAVIOR_POLICY
  SAFEGUARDING
  ACADEMIC_POLICY
  SCHOOL_PHILOSOPHY
  PARENT_COMMUNICATION
  INCIDENT_ESCALATION
  AI_USAGE_POLICY
  CLASSROOM_OPERATIONS
  TRANSFORMATION_NOTES
  OTHER
}


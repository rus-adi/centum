# =========================
# Database (Prisma + Postgres)
# =========================
# Supabase Postgres example:
# DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"
# DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"
#
# Tip: In production you may use a pooled URL for DATABASE_URL and a direct URL for DIRECT_URL.
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"

# =========================
# NextAuth
# =========================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# =========================
# Email (optional)
# =========================
# If RESEND_API_KEY is set, invite/reset emails will be sent.
# If not set, the app will show a debug link in dev mode (EMAIL_DEBUG_LINKS=true).
RESEND_API_KEY=""
EMAIL_FROM="Centum Portal <no-reply@yourdomain.com>"
EMAIL_DEBUG_LINKS="true"

# =========================
# Supabase Storage (attachments)
# =========================
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="attachments"
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS="600"

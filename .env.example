# =========================
# Database (Prisma + Postgres)
# =========================
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?schema=public"

# =========================
# NextAuth
# =========================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# =========================
# Email (optional)
# =========================
RESEND_API_KEY=""
EMAIL_FROM="Centum Stack <no-reply@yourdomain.com>"
EMAIL_DEBUG_LINKS="true"

# =========================
# Supabase Storage (optional)
# =========================
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="attachments"
SUPABASE_STORAGE_SIGNED_URL_TTL_SECONDS="600"

# =========================
# Optional LLM provider settings
# =========================
# Governance Q&A and Copilot both work without these values by using deterministic fallback logic.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://api.openai.com/v1"

# =========================
# Optional external offering links
# Yellow offering cards in the UI indicate these are still placeholders.
# Replace any of these later without changing page structure.
# =========================
NEXT_PUBLIC_RESILIENCY_LESSON_PLANS_URL="https://example.com/resiliency-lesson-plans"
